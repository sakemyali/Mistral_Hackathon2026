# Mistral API (all models via Mistral cloud)
MISTRAL_API_KEY=your_key_here

# Models for JSON image pipeline
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_TEXT_MODEL=mistral-large-latest

# (optional) legacy classifier model
MINISTRAL_MODEL=ministral-3b-latest
MISTRAL_CALL_TIMEOUT_MS=45000

# Pipeline settings
OCR_FPS=2
VISION_FPS=0.25
CLASSIFIER_FPS=0.5
CAPTURE_MONITOR=1
WS_PORT=8000

# Weights & Biases (optional)
WANDB_API_KEY=your_key_here
WANDB_ENABLED=false
WANDB_PROJECT=doraemon
WANDB_RUN_NAME=

ELEVENLABS_API_KEY=your_elevenlabs_key_here