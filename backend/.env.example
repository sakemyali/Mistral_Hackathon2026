# Mistral API (all models via Mistral cloud)
MISTRAL_API_KEY=your_key_here

# Ministral model for classification & translation
MINISTRAL_MODEL=ministral-3b-latest

# Pipeline settings
OCR_FPS=2
VISION_FPS=0.25
CLASSIFIER_FPS=0.5
CAPTURE_MONITOR=1
WS_PORT=8000

# Weights & Biases (optional)
WANDB_API_KEY=your_key_here
WANDB_ENABLED=false
WANDB_PROJECT=doraemon
WANDB_RUN_NAME=
