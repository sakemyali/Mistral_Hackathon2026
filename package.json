{
  "name": "ghost-overlay",
  "version": "1.0.0",
  "description": "Transparent AI overlay — always-on-top HUD with glassmorphism UI",
  "main": "main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "start": "webpack --config webpack.config.js && electron .",
    "dev": "webpack --config webpack.config.js --mode development && electron . --dev"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron": "^33.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.16",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "build": {
    "appId": "com.ghost.overlay",
